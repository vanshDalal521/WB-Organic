{
  "expo": {
    "name": "WB Organic Dairy",
    "slug": "wb-organic-dairy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#176B32"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wborganicdairy.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#176B32"
      },
      "package": "com.wborganicdairy.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-location",
      "expo-camera",
      "expo-image-picker",
      "expo-notifications"
    ],
    "scheme": "wborganicdairy",
    "extra": {
      "apiUrl": "http://localhost:3000",
      "eas": {
        "projectId": "your-project-id"
      }
    }
  }
}
